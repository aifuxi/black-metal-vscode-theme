{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "insertFinalNewline": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules/**",
    "themes/**",
    "parts/**",
    "assets/**",
    ".worktrees/**",
    ".agents/**",
    ".claude/**"
  ]
}
